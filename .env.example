# Telegram bot token from @BotFather
BOT_TOKEN=

# Max pairwise distance (km) for a group to form
GROUP_RADIUS_KM=5

# Members per group
GROUP_SIZE=3

# true = one account may submit multiple locations (each = a separate participant)
TEST_MODE=true

# Optional. When set, the /live admin panel requires this token (Bearer) for
# state data, exports, and rebuild. Leave empty for open localhost-only access.
ADMIN_TOKEN=
